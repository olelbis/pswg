PackageIdentifier: olelbis.pswg
PackageVersion: "{{VERSION}}"
InstallerLocale: en-US
InstallerType: zip
ReleaseDate: "{{RELEASE_DATE}}"
Installers:
  - Architecture: x64
    InstallerUrl: https://github.com/olelbis/pswg/releases/download/v{{VERSION}}/pswg_v{{VERSION}}_windows_amd64.zip
    InstallerSha256: "{{WINDOWS_AMD64_SHA256}}"
    NestedInstallerType: portable
    NestedInstallerFiles:
      - RelativeFilePath: pswg.exe
        PortableCommandAlias: pswg
  - Architecture: arm64
    InstallerUrl: https://github.com/olelbis/pswg/releases/download/v{{VERSION}}/pswg_v{{VERSION}}_windows_arm64.zip
    InstallerSha256: "{{WINDOWS_ARM64_SHA256}}"
    NestedInstallerType: portable
    NestedInstallerFiles:
      - RelativeFilePath: pswg.exe
        PortableCommandAlias: pswg
ManifestType: installer
ManifestVersion: 1.9.0
